{
  "permissions": {
    "allow": [
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(gws *)",
      "Bash(python3 *)",
      "Bash(cat *)",
      "Bash(cd * && git *)",
      "mcp__linear__*"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"タスクが完了しました\" with title \"agents\"'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e \"display notification \\\"$CLAUDE_NOTIFICATION_MESSAGE\\\" with title \\\"agents\\\"\""
          }
        ]
      }
    ]
  }
}
